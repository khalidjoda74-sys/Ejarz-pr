<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ثيم شاشة الإقلاع (Android 12+) -->
    <style name="LaunchTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <!-- لون الخلفية يطابق سبلاشك -->
        <!-- أيقونة/شعار السبلاش: استخدم موجود فعلاً لديك -->
        <!-- بدون خلفية دائرية للشعار -->
        <!-- اختياري -->
        <!-- خلفية النافذة fallback (نادر الاحتياج) -->
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowSplashScreenBackground">#FFFFFF</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/android12splash</item>
    </style>
    <!-- الثيم العادي بعد الإقلاع -->
    <style name="NormalTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
